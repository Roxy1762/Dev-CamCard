# Dev-CamCard · 课表风暴  deployment env
# 复制为 .env 后按需修改。scripts/deploy.sh 会在缺失时自动创建。

# ── PostgreSQL（docker-compose 内部网络使用） ─────────────────────────────
POSTGRES_USER=camcard
POSTGRES_PASSWORD=camcard
POSTGRES_DB=camcard
# 宿主机暴露端口（避免与本地其它 PG 冲突可改 5433）
POSTGRES_HOST_PORT=5432

# ── 房间服务 server（Colyseus + Express） ────────────────────────────────
SERVER_PORT=2567
# 逗号分隔：同时允许 Phaser 客户端 与 Next.js 后台 的本地 origin。
# 线上部署请替换成真实域名（例如 https://play.example.com）。
CLIENT_ORIGIN=http://localhost:3000,http://localhost:3001

# ── 游戏前端（Phaser） ────────────────────────────────────────────────────
# 构建期注入；若使用 nginx 反代同域 /ws 可留空以走同 host 自动推导。
VITE_SERVER_URL=ws://localhost:2567
CLIENT_HOST_PORT=3000

# ── 管理后台（Next.js） ───────────────────────────────────────────────────
ADMIN_HOST_PORT=3001
# 容器内部访问 server 的地址（Next.js API 代理路由使用，不暴露给浏览器）
ADMIN_API_BASE=http://server:2567
# 若需在页面上显示公网 server 地址，可额外设置（可选）：
# NEXT_PUBLIC_API_BASE=http://your-server-ip:2567
