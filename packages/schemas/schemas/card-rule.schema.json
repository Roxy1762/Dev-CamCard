{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "card-rule",
  "title": "CardRule",
  "description": "卡牌规则数据（v2 分层格式）— 不含本地化文案，仅包含规则与元数据字段。\n规则与文案分层的原因：规则数据是引擎的真源，文案随 locale 变化；两者分离后可独立版本化、多语言扩展、mod 覆盖。",
  "type": "object",
  "required": ["id", "schemaVersion", "contentVersion", "cost", "rarity", "lane", "type", "tags", "abilities"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "卡牌唯一 ID，以 card-catalog.md 为准，不得擅自修改"
    },
    "schemaVersion": {
      "type": "integer",
      "minimum": 2,
      "description": "schema 版本；v2 分层格式起始值为 2"
    },
    "contentVersion": {
      "type": "integer",
      "minimum": 1,
      "description": "内容版本，每次改动数值字段或效果时递增"
    },
    "cost": {
      "type": "integer",
      "minimum": 0,
      "description": "购买费用（资源）"
    },
    "rarity": {
      "type": "string",
      "enum": ["common", "uncommon", "rare", "signature"],
      "description": "稀有度"
    },
    "lane": {
      "type": "string",
      "enum": ["course", "activity", "daily"],
      "description": "所属商店栏（三栏商店）"
    },
    "type": {
      "type": "string",
      "enum": ["action", "venue"]
    },
    "isGuard": {
      "type": "boolean",
      "description": "是否为值守场馆（type=venue 时生效）"
    },
    "durability": {
      "type": "integer",
      "minimum": 1,
      "description": "场馆耐久度（type=venue 时有效）"
    },
    "activationsPerTurn": {
      "type": "integer",
      "minimum": 0,
      "description": "场馆每回合最多启动次数（type=venue 时有效）"
    },
    "starter": {
      "type": "boolean",
      "description": "是否属于起始套牌"
    },
    "fixedSupply": {
      "type": "boolean",
      "description": "是否属于固定补给牌堆（无限）"
    },
    "isPressure": {
      "type": "boolean",
      "description": "是否为压力状态牌（不可打出，回合结束弃置）"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "题材标签，仅作分类，不作为规则类型"
    },
    "artKey": {
      "type": "string",
      "description": "美术资源键名（默认等于 id）；供客户端加载贴图时使用"
    },
    "abilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/Ability" },
      "description": "能力列表（触发器 + 效果）"
    },
    "balance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "notes": { "type": "string", "description": "平衡性备注" }
      }
    }
  },
  "$defs": {
    "Ability": {
      "type": "object",
      "required": ["trigger", "effects"],
      "additionalProperties": false,
      "properties": {
        "trigger": {
          "type": "string",
          "enum": [
            "onPlay",
            "onScheduleResolve",
            "onActivate",
            "onTurnStart",
            "onTurnEnd",
            "onBuy",
            "passive"
          ]
        },
        "effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/Effect" }
        },
        "condition": {
          "type": "string",
          "description": "触发条件（自由文本，供 engine 解析）"
        }
      }
    },
    "Effect": {
      "type": "object",
      "required": ["op"],
      "additionalProperties": true,
      "properties": {
        "op": {
          "type": "string",
          "enum": [
            "gainResource",
            "gainAttack",
            "gainBlock",
            "heal",
            "draw",
            "scry",
            "drawThenDiscard",
            "trashFromHandOrDiscard",
            "createPressure",
            "setFlag",
            "gainFaceUpCard",
            "queueDelayedDiscard",
            "chooseTarget"
          ],
          "description": "效果操作码白名单 — 非白名单 op 将被 AJV 拒绝"
        }
      }
    }
  }
}
