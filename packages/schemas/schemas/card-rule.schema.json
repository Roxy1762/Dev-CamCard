{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "card-rule",
  "title": "CardRule",
  "description": "卡牌规则数据（v2 分层格式）— 不含本地化文案，仅包含规则与元数据字段。\n规则与文案分层的原因：规则数据是引擎的真源，文案随 locale 变化；两者分离后可独立版本化、多语言扩展、mod 覆盖。",
  "type": "object",
  "required": ["id", "schemaVersion", "contentVersion", "cost", "rarity", "lane", "type", "tags", "abilities"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "卡牌唯一 ID，以 card-catalog.md 为准，不得擅自修改"
    },
    "schemaVersion": {
      "type": "integer",
      "minimum": 2,
      "description": "schema 版本；v2 分层格式起始值为 2"
    },
    "contentVersion": {
      "type": "integer",
      "minimum": 1,
      "description": "内容版本，每次改动数值字段或效果时递增"
    },
    "cost": {
      "type": "integer",
      "minimum": 0,
      "description": "购买费用（资源）"
    },
    "rarity": {
      "type": "string",
      "enum": ["common", "uncommon", "rare", "signature"],
      "description": "稀有度"
    },
    "lane": {
      "type": "string",
      "enum": ["course", "activity", "daily"],
      "description": "所属商店栏（三栏商店）"
    },
    "type": {
      "type": "string",
      "enum": ["action", "venue"]
    },
    "isGuard": {
      "type": "boolean",
      "description": "是否为值守场馆（type=venue 时生效）"
    },
    "durability": {
      "type": "integer",
      "minimum": 1,
      "description": "场馆耐久度（type=venue 时有效）"
    },
    "activationsPerTurn": {
      "type": "integer",
      "minimum": 0,
      "description": "场馆每回合最多启动次数（type=venue 时有效）"
    },
    "starter": {
      "type": "boolean",
      "description": "是否属于起始套牌"
    },
    "fixedSupply": {
      "type": "boolean",
      "description": "是否属于固定补给牌堆（无限）"
    },
    "isPressure": {
      "type": "boolean",
      "description": "是否为压力状态牌（不可打出，回合结束弃置）"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "题材标签，仅作分类，不作为规则类型"
    },
    "artKey": {
      "type": "string",
      "description": "美术资源键名（默认等于 id）；供客户端加载贴图时使用"
    },
    "abilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/Ability" },
      "description": "能力列表（触发器 + 效果）"
    },
    "balance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "notes": { "type": "string", "description": "平衡性备注" }
      }
    }
  },
  "$defs": {
    "Ability": {
      "type": "object",
      "required": ["trigger", "effects"],
      "additionalProperties": false,
      "properties": {
        "trigger": {
          "type": "string",
          "enum": [
            "onPlay",
            "onScheduleResolve",
            "onActivate",
            "onTurnStart",
            "onTurnEnd",
            "onBuy",
            "passive"
          ]
        },
        "effects": {
          "type": "array",
          "items": { "$ref": "#/$defs/Effect" }
        },
        "condition": { "$ref": "#/$defs/Condition" }
      }
    },
    "Condition": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "type": { "const": "firstActionThisTurn" }
          }
        },
        {
          "additionalProperties": false,
          "required": ["count"],
          "properties": {
            "type": { "const": "actionsPlayedAtLeast" },
            "count": { "$ref": "#/$defs/PositiveInt" }
          }
        },
        {
          "additionalProperties": false,
          "properties": {
            "type": { "const": "hasVenue" }
          }
        },
        {
          "additionalProperties": false,
          "properties": {
            "type": { "const": "hasScheduledCard" }
          }
        },
        {
          "additionalProperties": false,
          "properties": {
            "type": { "const": "hasReservedCard" }
          }
        }
      ]
    },
    "Effect": {
      "type": "object",
      "required": ["op"],
      "oneOf": [
        { "$ref": "#/$defs/Effect_gainResource" },
        { "$ref": "#/$defs/Effect_gainAttack" },
        { "$ref": "#/$defs/Effect_gainBlock" },
        { "$ref": "#/$defs/Effect_heal" },
        { "$ref": "#/$defs/Effect_draw" },
        { "$ref": "#/$defs/Effect_drawThenDiscard" },
        { "$ref": "#/$defs/Effect_scry" },
        { "$ref": "#/$defs/Effect_trashFromHandOrDiscard" },
        { "$ref": "#/$defs/Effect_createPressure" },
        { "$ref": "#/$defs/Effect_setFlag" },
        { "$ref": "#/$defs/Effect_gainFaceUpCard" },
        { "$ref": "#/$defs/Effect_queueDelayedDiscard" },
        { "$ref": "#/$defs/Effect_chooseTarget" }
      ]
    },
    "NonNegInt": { "type": "integer", "minimum": 0 },
    "PositiveInt": { "type": "integer", "minimum": 1 },
    "Effect_gainResource": {
      "type": "object",
      "required": ["op", "amount"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "gainResource" },
        "amount": { "$ref": "#/$defs/NonNegInt" }
      }
    },
    "Effect_gainAttack": {
      "type": "object",
      "required": ["op", "amount"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "gainAttack" },
        "amount": { "$ref": "#/$defs/NonNegInt" }
      }
    },
    "Effect_gainBlock": {
      "type": "object",
      "required": ["op", "amount"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "gainBlock" },
        "amount": { "$ref": "#/$defs/NonNegInt" }
      }
    },
    "Effect_heal": {
      "type": "object",
      "required": ["op", "amount"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "heal" },
        "amount": { "$ref": "#/$defs/NonNegInt" }
      }
    },
    "Effect_draw": {
      "type": "object",
      "required": ["op", "count"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "draw" },
        "count": { "$ref": "#/$defs/PositiveInt" }
      }
    },
    "Effect_drawThenDiscard": {
      "type": "object",
      "required": ["op", "drawCount", "discardCount"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "drawThenDiscard" },
        "drawCount": { "$ref": "#/$defs/PositiveInt" },
        "discardCount": { "$ref": "#/$defs/NonNegInt" }
      }
    },
    "Effect_scry": {
      "type": "object",
      "required": ["op", "count"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "scry" },
        "count": { "$ref": "#/$defs/PositiveInt" },
        "interactive": { "type": "boolean" }
      }
    },
    "Effect_trashFromHandOrDiscard": {
      "type": "object",
      "required": ["op", "count"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "trashFromHandOrDiscard" },
        "count": { "$ref": "#/$defs/PositiveInt" },
        "zone": { "type": "string", "enum": ["hand", "discard", "either"] }
      }
    },
    "Effect_createPressure": {
      "type": "object",
      "required": ["op", "count"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "createPressure" },
        "count": { "$ref": "#/$defs/PositiveInt" },
        "target": { "type": "string", "enum": ["opponent", "self"] }
      }
    },
    "Effect_setFlag": {
      "type": "object",
      "required": ["op", "flag"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "setFlag" },
        "flag": { "type": "string", "minLength": 1 }
      }
    },
    "Effect_gainFaceUpCard": {
      "type": "object",
      "required": ["op", "maxCost"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "gainFaceUpCard" },
        "maxCost": { "$ref": "#/$defs/NonNegInt" },
        "destination": { "type": "string", "enum": ["discard", "deckTop"] }
      }
    },
    "Effect_queueDelayedDiscard": {
      "type": "object",
      "required": ["op", "count"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "queueDelayedDiscard" },
        "count": { "$ref": "#/$defs/PositiveInt" },
        "target": { "type": "string", "enum": ["opponent", "self"] }
      }
    },
    "Effect_chooseTarget": {
      "type": "object",
      "required": ["op", "targetType", "onChosen"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "chooseTarget" },
        "targetType": {
          "type": "string",
          "enum": ["opponentPlayer", "opponentVenue", "selfVenue"]
        },
        "onChosen": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/TargetedEffect" }
        }
      }
    },
    "TargetedEffect": {
      "type": "object",
      "required": ["op"],
      "oneOf": [
        { "$ref": "#/$defs/Targeted_damageVenue" },
        { "$ref": "#/$defs/Targeted_dealDamage" }
      ]
    },
    "Targeted_damageVenue": {
      "type": "object",
      "required": ["op", "amount"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "damageVenue" },
        "amount": { "$ref": "#/$defs/PositiveInt" }
      }
    },
    "Targeted_dealDamage": {
      "type": "object",
      "required": ["op", "amount"],
      "additionalProperties": false,
      "properties": {
        "op": { "const": "dealDamage" },
        "amount": { "$ref": "#/$defs/PositiveInt" }
      }
    }
  }
}
