{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ruleset",
  "title": "RulesetDef",
  "description": "规则集定义",
  "type": "object",
  "required": [
    "id",
    "version",
    "name",
    "hp",
    "handSize",
    "firstPlayerOpeningHand",
    "secondPlayerOpeningHand",
    "scheduleSlots",
    "reserveSlots",
    "marketLanesCount",
    "marketSlotsPerLane",
    "starterDeck",
    "fixedSupplies"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "hp": {
      "type": "integer",
      "minimum": 1,
      "description": "初始生命值（MVP=32）"
    },
    "handSize": {
      "type": "integer",
      "minimum": 1,
      "description": "手牌上限（MVP=5）"
    },
    "firstPlayerOpeningHand": {
      "type": "integer",
      "minimum": 1,
      "description": "先手首回合起手牌数（MVP=4）"
    },
    "secondPlayerOpeningHand": {
      "type": "integer",
      "minimum": 1,
      "description": "后手首回合起手牌数（MVP=5）"
    },
    "scheduleSlots": {
      "type": "integer",
      "minimum": 0,
      "description": "日程槽数量（MVP=2）"
    },
    "reserveSlots": {
      "type": "integer",
      "minimum": 0,
      "description": "预约位数量（MVP=1）"
    },
    "marketLanesCount": {
      "type": "integer",
      "minimum": 1,
      "description": "商店栏数（MVP=3）"
    },
    "marketSlotsPerLane": {
      "type": "integer",
      "minimum": 1,
      "description": "每栏槽位数（MVP=2）"
    },
    "starterDeck": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["cardId", "count"],
        "additionalProperties": false,
        "properties": {
          "cardId": { "type": "string" },
          "count": { "type": "integer", "minimum": 1 }
        }
      },
      "description": "起始套牌组成（cardId + 份数）"
    },
    "fixedSupplies": {
      "type": "array",
      "items": { "type": "string" },
      "description": "固定补给牌堆 cardId 列表（无限牌堆）"
    }
  }
}
