# Dev-CamCard · 课表风暴  deployment env
# 复制为 .env 后按需修改。scripts/deploy.sh 会在缺失时自动创建。

# ── PostgreSQL（docker-compose 内部网络使用） ─────────────────────────────
POSTGRES_USER=camcard
POSTGRES_PASSWORD=camcard
POSTGRES_DB=camcard
# 宿主机暴露端口（避免与本地其它 PG 冲突可改 5433）
POSTGRES_HOST_PORT=5432

# ── 房间服务 server（Colyseus + Express） ────────────────────────────────
# 容器内端口固定 2567；这里只决定宿主机暴露端口（公网部署可不暴露，由前端 nginx 反代）。
SERVER_HOST_PORT=2567
# CORS 白名单。* 放行任意来源，便于自托管 / 局域网 IP / 域名混用。
# 上线请收紧为逗号分隔列表，例：https://play.example.com,https://admin.example.com
CLIENT_ORIGIN=*

# ── 游戏前端（Phaser） ────────────────────────────────────────────────────
# 留空 → 客户端按 window.location 自动推导 ws 地址，并由 nginx 反代到 server。
# 这样无论部署在 localhost / 公网 IP / 域名，浏览器都能直接连上，无需改配置。
# 仅在需要把 ws 指向独立端点（例如另一台机器）时才显式设置：
#   VITE_SERVER_URL=wss://play.example.com
VITE_SERVER_URL=
CLIENT_HOST_PORT=3000

# ── 管理后台（Next.js） ───────────────────────────────────────────────────
ADMIN_HOST_PORT=3001
# 容器内部访问 server 的地址（Next.js API 代理路由使用，不暴露给浏览器）
ADMIN_API_BASE=http://server:2567
# 若需在页面上显示公网 server 地址，可额外设置（可选）：
# NEXT_PUBLIC_API_BASE=http://your-server-ip:2567
